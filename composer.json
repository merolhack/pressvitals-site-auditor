{
    "name": "omnihealth/site-auditor",
    "description": "A headless-first WordPress diagnostic engine with 22+ proactive probes for performance, security, and DB health.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "site-health",
        "monitoring",
        "security",
        "rest-api"
    ],
    "homepage": "https://wordpress.org/plugins/omnihealth-site-auditor/",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "*",
        "wp-coding-standards/wpcs": "*",
        "dealerdirect/phpcodesniffer-composer-installer": "*"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "find . -path ./vendor -prune -o -name '*.php' -print0 | xargs -0 -n1 -P4 php -l",
        "make-pot": "wp i18n make-pot . languages/omnihealth-site-auditor.pot",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
